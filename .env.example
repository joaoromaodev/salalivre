# Connection string do Postgres (Neon, Supabase, RDS, local — qualquer
# provedor). Em geral inclui `?sslmode=require` quando o provedor exige SSL.
DATABASE_URL=postgres://usuario:senha@host:5432/nome_do_banco

# Senha única e compartilhada que dá acesso ao sistema. Troque por um
# valor forte antes de colocar em produção.
APP_PASSWORD=troque-esta-senha

# Segredo usado para assinar (HMAC) o cookie de sessão. Gere um valor
# aleatório longo, por exemplo: openssl rand -base64 32
COOKIE_SECRET=troque-este-segredo-por-um-valor-aleatorio-longo
